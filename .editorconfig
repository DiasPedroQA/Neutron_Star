# Indica que este é o arquivo .editorconfig raiz do repositório.
root = true

# Regras padrão aplicadas a todos os arquivos.
[*]
# Codificação de caracteres padrão: UTF-8.
charset = utf-8
# Fim de linha no estilo Unix (LF).
end_of_line = lf
# Garante uma linha em branco no final de cada arquivo.
insert_final_newline = true
# Remove espaços em branco ao final das linhas ao salvar.
trim_trailing_whitespace = true
# Usa espaços (e não tabs) para indentação.
indent_style = space
# Tamanho da indentação em 4 espaços.
indent_size = 4
